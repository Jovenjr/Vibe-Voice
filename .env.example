# Configuración de ejemplo para Vibe Voice
# Copia este archivo a .env y completa solo lo que vayas a usar.

# Docker / watchers
# En Windows con Docker Desktop usa formato /c/Users/...
# APPDATA_PATH=/c/Users/TuUsuario/AppData/Roaming

# LLM para resumir texto antes de TTS
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Dictado con OpenAI
OPENAI_API_KEY=
OPENAI_AUDIO_MODEL=whisper-1
OPENAI_AUDIO_TRANSCRIPTIONS_URL=https://api.openai.com/v1/audio/transcriptions

# Dictado con Groq
GROQ_API_KEY=
GROQ_AUDIO_MODEL=whisper-large-v3-turbo

# Proveedor por defecto para dictado: local | groq | openai | auto
DICTATION_PROVIDER=auto

# Telegram opcional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# STT opcional para telegram_input.py
STT_PROVIDER=groq
WHISPER_MODEL=base
